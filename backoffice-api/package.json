{
  "name": "backoffice-api",
  "version": "1.0.0",
  "description": "A serverless API",
  "scripts": {
    "dev": "docker compose up",
    "dev:down": "docker compose down",
    "cdk:synth": "cdk synth",
    "cdk:diff": "cdk diff",
    "cdk:deploy": "cdk deploy --all",
    "cdk:destroy": "cdk destroy --all",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "check": "npm run lint && npm run typecheck && npm run test"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.758.0",
    "@aws-sdk/lib-dynamodb": "^3.758.0"
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.11",
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^24.12.0",
    "aws-cdk": "^2.1111.0",
    "aws-cdk-lib": "^2.243.0",
    "hono": "^4.12.7",
    "nodemon": "^3.1.10",
    "oxlint": "^1.51.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=24"
  },
  "license": "MIT"
}
