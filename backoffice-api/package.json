{
  "name": "backoffice-api",
  "version": "1.0.0",
  "description": "A serverless API",
  "main": "src/index.ts",
  "scripts": {
    "start": "serverless offline start",
    "offline": "serverless offline start",
    "build": "tsc",
    "deploy": "serverless deploy",
    "deploy:info": "serverless info",
    "remove": "serverless remove",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.1006.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "oxlint": "^1.51.0",
    "serverless": "^3.40.0",
    "serverless-offline": "^13.8.1",
    "serverless-plugin-typescript": "^2.1.5",
    "typescript": "^4.9.5",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
