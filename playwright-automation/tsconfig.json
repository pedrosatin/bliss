{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": ".",
    "outDir": "dist"
  },
  "include": ["index.ts", "src/**/*.ts", "playwright.config.ts"],
  "exclude": ["node_modules", "playwright-report", "test-results", "dist"]
}
